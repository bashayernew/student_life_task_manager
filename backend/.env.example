# Server
PORT=4000

# Required — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Super admin created automatically on startup if missing
SUPERADMIN_EMAIL=superadmin@admin.com
SUPERADMIN_PASSWORD=change-me-in-production

# Optional — SQLite database file path
# DATABASE_PATH=./data/app.db

# Optional — only used when running `npm run seed` on an empty database
SEED_ADMIN_EMAIL=superadmin@admin.com
SEED_ADMIN_PASSWORD=change-me-before-seeding
SEED_MANAGER_PASSWORD=change-me-before-seeding
SEED_STAFF_PASSWORD=change-me-before-seeding
