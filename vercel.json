{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "devCommand": "npm run dev:web",
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
