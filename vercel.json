{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "devCommand": "npm run dev:web",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
