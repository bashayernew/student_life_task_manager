# Frontend API base URL (no trailing slash)
# Leave empty on Vercel and for local Vite dev (same-origin /api via proxy).
# Set only when the API is hosted on a different origin.
VITE_API_URL=

# --- Server / Vercel serverless API ---

# Neon Postgres (required). Vercel Neon integration sets DATABASE_URL automatically.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT signing secret (required in production — use a long random string)
JWT_SECRET=replace-with-a-long-random-secret

# Super admin created on first request if missing
SUPERADMIN_EMAIL=superadmin@admin.com
SUPERADMIN_PASSWORD=Adm!n@123

# Optional — local API port when running backend/src/index.js directly
PORT=4000

# Optional — only used when running `npm run seed` in /backend on an empty database
SEED_ADMIN_EMAIL=superadmin@admin.com
SEED_ADMIN_PASSWORD=change-me-before-seeding
SEED_MANAGER_PASSWORD=change-me-before-seeding
SEED_STAFF_PASSWORD=change-me-before-seeding
