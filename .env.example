# =============================================================================
# Copy to `.env` for local development (`npm run dev` → vercel dev).
# Set the same server vars in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# --- Frontend (optional) ---
# Leave empty so the app calls same-origin `/api` (vercel dev + production).
# Only set when the API runs on a different host, e.g. https://api.example.com
VITE_API_URL=

# --- Server / Vercel serverless (required) ---

# Neon Postgres. Vercel Neon integration sets DATABASE_URL automatically in production.
# IMPORTANT: Data (users, tasks, departments) lives in this database. Do not change
# DATABASE_URL to a new empty database unless you intend to start fresh. Deploying
# code does NOT delete data — only pointing at a different DB makes accounts disappear.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# JWT signing secret — use a long random string in production
JWT_SECRET=replace-with-a-long-random-secret

# Super admin bootstrapped on first API request if this email does not exist
SUPERADMIN_EMAIL=superadmin@admin.com
SUPERADMIN_PASSWORD=Adm!n@123

# --- Optional ---

# Only for `npm run dev:express` (legacy standalone server)
PORT=4000

# Only for `npm run seed` in /backend (seed script may need Neon update)
SEED_ADMIN_EMAIL=superadmin@admin.com
SEED_ADMIN_PASSWORD=change-me-before-seeding
SEED_MANAGER_PASSWORD=change-me-before-seeding
SEED_STAFF_PASSWORD=change-me-before-seeding
